# Ritual testnet deployer — an EOA holding RITUAL for gas.
# NEVER commit private keys / passwords. Copy this file to .env and fill in real values.
# The Next.js frontend only needs RITUAL_RPC_URL; the deploy script needs DEPLOYER_PASS + DEPLOYER_ADDR.

# Ritual testnet RPC (frontend + deploy)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Deploy script (scripts/deploy.sh) — do NOT set on Vercel, local only.
DEPLOYER_PASS=
DEPLOYER_ADDR=

# API gateway signer (optional, local/api-gateway only). NEVER commit.
SIGNER_PK=
