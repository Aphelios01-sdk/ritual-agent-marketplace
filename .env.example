# Ritual testnet deployer — EOA dengan RITUAL buat gas.
# Private key / password JANGAN commit. Copy file ini jadi .env, isi nilai asli.
# Frontend (Next.js) hanya butuh RITUAL_RPC_URL; deploy script butuh DEPLOYER_PASS + DEPLOYER_ADDR.

# Ritual testnet RPC (frontend + deploy)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Deploy script (scripts/deploy.sh) — JANGAN set di Vercel, hanya lokal.
DEPLOYER_PASS=
DEPLOYER_ADDR=

# API gateway signer (opsional, hanya lokal/api-gateway). JANGAN commit.
SIGNER_PK=
